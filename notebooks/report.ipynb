   "source": [
    "rating_dist = (\n",
    "    reviews.groupby(['company', 'rating'])\n",
    "    .size()\n",
    "    .unstack(fill_value=0)\n",
    "    .reindex(columns=[1, 2, 3, 4, 5], fill_value=0)\n",
    ")\n",
    "\n",
    "# Нормируем в проценты\n",
    "rating_pct = rating_dist.div(rating_dist.sum(axis=1), axis=0) * 100\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "\n",
    "x = np.arange(len(rating_pct))\n",
    "width = 0.15\n",
    "colors = ['#e74c3c', '#e67e22', '#f1c40f', '#2ecc71', '#27ae60']\n",
    "\n",
    "for i, rating in enumerate([1, 2, 3, 4, 5]):\n",
    "    ax.bar(x + i * width, rating_pct[rating], width, label=f'★ {rating}', color=colors[i])\n",
    "\n",
    "ax.set_xticks(x + width * 2)\n",
    "ax.set_xticklabels(rating_pct.index, rotation=15, ha='right')\n",
    "ax.set_ylabel('Доля отзывов, %')\n",
    "ax.set_title('Распределение оценок по компаниям')\n",
    "ax.legend(title='Оценка', bbox_to_anchor=(1.01, 1), loc='upper left')\n",
    "ax.yaxis.set_major_formatter(mticker.FormatStrFormatter('%.0f%%'))\n",
    "ax.grid(axis='y', alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "rating_pct.round(1)"
   ]
  },
