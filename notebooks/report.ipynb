   "source": [
    "negative = reviews[reviews['rating'] <= 3].copy()\n",
    "\n",
    "reply_stats = (\n",
    "    negative.groupby('company')\n",
    "    .agg(\n",
    "        total=('rating', 'count'),\n",
    "        with_reply=('reply', lambda x: x.notna().sum())\n",
    "    )\n",
    "    .assign(reply_rate=lambda df: df['with_reply'] / df['total'] * 100)\n",
    "    .sort_values('reply_rate', ascending=True)\n",
    ")\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 4))\n",
    "bars = ax.barh(reply_stats.index, reply_stats['reply_rate'], color='#3498db', alpha=0.8)\n",
    "\n",
    "for bar, (_, row) in zip(bars, reply_stats.iterrows()):\n",
    "    ax.text(\n",
    "        bar.get_width() + 0.5, bar.get_y() + bar.get_height() / 2,\n",
    "        f\"{row['reply_rate']:.1f}%  ({int(row['with_reply'])}/{int(row['total'])})\",\n",
    "        va='center', fontsize=9\n",
    "    )\n",
    "\n",
    "ax.set_xlabel('Доля негативных отзывов с ответом, %')\n",
    "ax.set_title('Доля негативных отзывов с ответом поддержки')\n",
    "ax.set_xlim(0, 110)\n",
    "ax.xaxis.set_major_formatter(mticker.FormatStrFormatter('%.0f%%'))\n",
    "ax.grid(axis='x', alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "reply_stats"
   ]
  },
