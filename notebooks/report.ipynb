   "source": [
    "import sqlite3\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as mticker\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "\n",
    "pd.set_option('display.max_colwidth', None)\n",
    "plt.rcParams['figure.dpi'] = 120\n",
    "plt.rcParams['font.size'] = 10\n",
    "\n",
    "DB_PATH = Path("../data/reviews.db")\n",
    "conn = sqlite3.connect(DB_PATH)\n",
    "print('✅ Подключено к', DB_PATH)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Компании: ['immobilienscout24', 'rentumo', 'immosurf', 'immowelt']\n",
      "Отзывов: 172, категорий: 75\n"
     ]
    }
   ],
   "source": [
    "# Загружаем отзывы и категории\n",
    "reviews = pd.read_sql(\n",
    "    'SELECT company, rating, reply FROM reviews WHERE rating IS NOT NULL',\n",
    "    conn\n",
    ")\n",
    "\n",
    "# Берём только последний прогон анализа для каждой компании\n",
    "latest_runs = pd.read_sql(\"\"\"\n",
    "    SELECT company, MAX(analyzed_at) AS last_run\n",
    "    FROM categories\n",
    "    GROUP BY company\n",
    "\"\"\", conn)\n",
    "\n",
    "categories = pd.read_sql(\"\"\"\n",
    "    SELECT c.company, c.group_type, c.name, c.count, c.analyzed_at\n",
    "    FROM categories c\n",
    "    JOIN (\n",
    "        SELECT company, MAX(analyzed_at) AS last_run\n",
    "        FROM categories GROUP BY company\n",
    "    ) lr ON c.company = lr.company AND c.analyzed_at = lr.last_run\n",
    "\"\"\", conn)\n",
    "\n",
    "# Порядок компаний\n",
    "companies = reviews['company'].unique().tolist()\n",
    "print(f'Компании: {companies}')\n",
    "print(f'Отзывов: {len(reviews)}, категорий: {len(categories)}')"
   ]
  },
  {
