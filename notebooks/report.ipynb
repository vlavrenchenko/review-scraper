    "neg_cats = (\n",
    "    categories[categories['group_type'] == 'negative']\n",
    "    .sort_values(['company', 'count'], ascending=[True, False])\n",
    "    .groupby('company')\n",
    "    .head(5)\n",
    ")\n",
    "\n",
    "company_list = neg_cats['company'].unique()\n",
    "n = len(company_list)\n",
    "fig, axes = plt.subplots(1, n, figsize=(5 * n, 5), sharey=False)\n",
    "if n == 1:\n",
    "    axes = [axes]\n",
    "\n",
    "for ax, company in zip(axes, company_list):\n",
    "    data = neg_cats[neg_cats['company'] == company].head(5)\n",
    "    ax.barh(data['name'][::-1], data['count'][::-1], color='#e74c3c', alpha=0.8)\n",
    "    ax.set_title(company, fontweight='bold')\n",
    "    ax.set_xlabel('Упоминаний')\n",
    "    ax.xaxis.set_major_locator(mticker.MaxNLocator(integer=True))\n",
    "    ax.grid(axis='x', alpha=0.3)\n",
    "\n",
    "fig.suptitle('Топ-5 категорий негативных отзывов', fontsize=13, fontweight='bold', y=1.02)\n",
